            {/* Quick actions */}
            <SectionCard style={{marginBottom:14}}>
              <div style={{padding:'16px 16px 8px',fontSize:11,color:MUTED,textTransform:'uppercase',letterSpacing:'.1em',fontWeight:700}}>Quick Actions</div>
              <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:8,padding:'0 12px 14px'}}>
                {[
                  {label:'Create Battle',icon:'⚔️',action:()=>{setSection('battles');setShowCreate(true);}},
                  {label:'View Battles',icon:'📋',action:()=>setSection('battles')},
                  {label:'View Users',icon:'👥',action:()=>setSection('users')},
                  {label:'Refresh Data',icon:'🔄',action:loadData},
                ].map(q=>(
                  <motion.button key={q.label} whileTap={{scale:0.94}} onClick={q.action}
