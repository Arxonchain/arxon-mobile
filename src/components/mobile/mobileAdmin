                      <div style={{display:'flex',flexDirection:'column',alignItems:'center',gap:5}}>
                        {b.side_a_image
                          ? <img src={b.side_a_image} alt="" style={{width:44,height:44,borderRadius:12,objectFit:'cover',border:`1px solid ${BORDER}`}}/>
                          : <div style={{width:44,height:44,borderRadius:12,background:`${STEEL}18`,border:`1px solid ${STEEL}30`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:14,fontWeight:800,color:STEEL}}>
                              {(b.side_a_name||'A').slice(0,2).toUpperCase()}
                            </div>}
                        <div style={{fontSize:10,fontWeight:700,color:TEXT,textAlign:'center',maxWidth:72,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{b.side_a_name}</div>
                        <div style={{fontSize:11,color:STEEL,fontWeight:700}}>{b.side_a_power.toLocaleString()}</div>
                      </div>
                      <div style={{fontSize:10,fontWeight:900,color:MUTED,padding:'4px 6px'}}>VS</div>
                      <div style={{display:'flex',flexDirection:'column',alignItems:'center',gap:5}}>
                        {b.side_b_image
                          ? <img src={b.side_b_image} alt="" style={{width:44,height:44,borderRadius:12,objectFit:'cover',border:`1px solid ${BORDER}`}}/>
                          : <div style={{width:44,height:44,borderRadius:12,background:`${GOLD}18`,border:`1px solid ${GOLD}30`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:14,fontWeight:800,color:GOLD}}>
                              {(b.side_b_name||'B').slice(0,2).toUpperCase()}
                            </div>}
                        <div style={{fontSize:10,fontWeight:700,color:TEXT,textAlign:'center',maxWidth:72,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{b.side_b_name}</div>
                        <div style={{fontSize:11,color:GOLD,fontWeight:700}}>{b.side_b_power.toLocaleString()}</div>
                      </div>
                    </div>

                    {/* Time */}
                    <div style={{fontSize:10,color:MUTED,marginTop:8,textAlign:'center'}}>
                      Ends: {new Date(b.ends_at).toLocaleString()}
                    </div>
                  </div>

                  {/* Action row */}
                  {!b.winner_side && (
                    <div style={{display:'flex',gap:6,padding:'8px 12px 12px'}}>
                      <button onClick={()=>resolve(b.id,'a')} disabled={!!resolving}
                        style={{flex:1,padding:'9px 6px',borderRadius:12,border:`1px solid ${STEEL}30`,
                          background:`${STEEL}10`,color:STEEL,fontSize:11,fontWeight:700,cursor:'pointer'}}>
                        {resolving===b.id?'…':`✓ ${b.side_a_name.slice(0,8)} wins`}
                      </button>
                      <button onClick={()=>toggleActive(b)}
                        style={{padding:'9px 12px',borderRadius:12,border:`1px solid ${BORDER}`,
                          background:'transparent',color:MUTED,fontSize:11,fontWeight:700,cursor:'pointer'}}>
                        {b.is_active?'⏸':'▶'}
                      </button>
                      <button onClick={()=>resolve(b.id,'b')} disabled={!!resolving}
                        style={{flex:1,padding:'9px 6px',borderRadius:12,border:`1px solid ${GOLD}30`,
                          background:`${GOLD}10`,color:GOLD,fontSize:11,fontWeight:700,cursor:'pointer'}}>
                        {resolving===b.id?'…':`✓ ${b.side_b_name.slice(0,8)} wins`}
                      </button>
                    </div>
                  )}
                  <div style={{padding:'0 12px 10px',display:'flex',justifyContent:'flex-end'}}>
                    <button onClick={()=>deleteBattle(b.id)}
                      style={{padding:'5px 12px',borderRadius:10,border:`1px solid ${ROSE}20`,
                        background:`${ROSE}08`,color:ROSE,fontSize:10,fontWeight:700,cursor:'pointer'}}>
                      Delete
                    </button>
                  </div>
                </SectionCard>
              ))}
          </motion.div>
        )}

        {/* ═══ USERS ═══ */}
        {section==='users' && (
          <motion.div initial={{opacity:0,y:8}} animate={{opacity:1,y:0}}>
            <div style={{marginBottom:12,fontSize:13,color:MUTED}}>{users.length} users shown</div>
            {loading?<div style={{display:'flex',justifyContent:'center',padding:40}}><Spinner/></div>:
              <SectionCard>
                {users.map((u,i)=>(
                  <div key={u.id} style={{padding:'12px 16px',borderTop:i?`1px solid ${BORDER}`:'none',
                    display:'flex',alignItems:'center',gap:10}}>
                    <div style={{width:36,height:36,borderRadius:12,background:`${STEEL}18`,
                      border:`1px solid ${STEEL}25`,display:'flex',alignItems:'center',justifyContent:'center',
                      fontSize:13,fontWeight:800,color:STEEL,flexShrink:0}}>
                      {(u.email||'?')[0].toUpperCase()}
                    </div>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontSize:13,fontWeight:600,color:TEXT,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{u.email}</div>
                      <div style={{fontSize:10,color:MUTED,marginTop:1}}>{new Date(u.created_at).toLocaleDateString()}</div>
                    </div>
                  </div>
                ))}
              </SectionCard>}
          </motion.div>
        )}
      </div>

      {/* Create Battle Sheet */}
      <AnimatePresence>
        {showCreate && (
          <>
            <motion.div initial={{opacity:0}} animate={{opacity:1}} exit={{opacity:0}}
              onClick={()=>setShowCreate(false)}
              style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.7)',zIndex:90}}/>
            <motion.div initial={{y:'100%'}} animate={{y:0}} exit={{y:'100%'}}
              transition={{type:'spring',stiffness:380,damping:36}}
              style={{position:'fixed',bottom:0,left:0,right:0,zIndex:100,
                background:'hsl(225 28% 7%)',borderRadius:'26px 26px 0 0',
                border:`1px solid ${BORDER}`,borderBottom:'none',maxHeight:'90vh',overflow:'hidden'}}>
              <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'18px 20px 14px'}}>
                <div style={{fontSize:17,fontWeight:900,color:TEXT}}>⚔️ New Battle</div>
                <button onClick={()=>setShowCreate(false)}
                  style={{width:32,height:32,borderRadius:10,background:'hsl(225 26% 12%)',
                    border:`1px solid ${BORDER}`,color:MUTED,fontSize:16,cursor:'pointer',
                    display:'flex',alignItems:'center',justifyContent:'center'}}>×</button>
              </div>
              <CreateBattleForm onClose={()=>setShowCreate(false)} onCreated={loadData}/>
            </motion.div>
          </>
        )}
      </AnimatePresence>
    </div>
  );
}
