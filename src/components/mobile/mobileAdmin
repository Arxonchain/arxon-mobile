                      <div style={{fontSize:13,fontWeight:700,color:TEXT,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{b.title}</div>
                      <div style={{fontSize:10,color:MUTED,marginTop:2}}>{b.side_a_name} vs {b.side_b_name}</div>
                    </div>
                    <div style={{fontSize:9,fontWeight:700,padding:'3px 8px',borderRadius:10,
                      color:b.winner_side?MINT:b.is_active?ROSE:MUTED,
                      background:b.winner_side?`${MINT}12`:b.is_active?`${ROSE}12`:`${MUTED}10`,
                      border:`1px solid ${b.winner_side?MINT+'30':b.is_active?ROSE+'30':BORDER}`}}>
                      {b.winner_side?'DONE':b.is_active?'LIVE':'PAUSED'}
                    </div>
                  </div>
                ))}
            </SectionCard>
          </motion.div>
        )}

        {/* ═══ BATTLES ═══ */}
        {section==='battles' && (
          <motion.div initial={{opacity:0,y:8}} animate={{opacity:1,y:0}}>
            <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:12}}>
              <div style={{fontSize:13,color:MUTED}}>{battles.length} battles total</div>
              <motion.button whileTap={{scale:0.94}} onClick={()=>setShowCreate(true)}
                style={{padding:'9px 18px',borderRadius:16,background:`${STEEL}18`,border:`1px solid ${STEEL}35`,
                  color:STEEL,fontSize:12,fontWeight:800,cursor:'pointer'}}>
                + New Battle
              </motion.button>
            </div>

            {loading ? <div style={{display:'flex',justifyContent:'center',padding:40}}><Spinner/></div> :
              battles.map(b=>(
                <SectionCard key={b.id} style={{marginBottom:10}}>
                  {/* Battle header */}
                  <div style={{padding:'14px 14px 10px'}}>
                    <div style={{display:'flex',alignItems:'flex-start',gap:10,marginBottom:10}}>
                      <div style={{flex:1,minWidth:0}}>
                        <div style={{fontSize:14,fontWeight:800,color:TEXT,marginBottom:3,lineHeight:1.3}}>{b.title}</div>
                        {b.description&&<div style={{fontSize:11,color:MUTED,lineHeight:1.4}}>{b.description}</div>}
                      </div>
                      <div style={{fontSize:9,fontWeight:700,padding:'4px 9px',borderRadius:10,flexShrink:0,
                        color:b.winner_side?MINT:b.is_active?ROSE:GOLD,
                        border:`1px solid ${b.winner_side?MINT+'30':b.is_active?ROSE+'30':GOLD+'30'}`,
                        background:b.winner_side?`${MINT}10`:b.is_active?`${ROSE}10`:`${GOLD}10`}}>
                        {b.winner_side?'RESOLVED':b.is_active?'LIVE':'PAUSED'}
